{
  "name": "retentia",
  "version": "0.2.0",
  "displayName": "Retentia",
  "description": "Persistent project memory MCP plugin for OpenAI Codex, Claude Code, and other major LLMs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "retentia": "dist/cli.js",
    "codex-mem": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "setup": "npm run build && node dist/cli.js setup",
    "enable": "npm run build && node dist/cli.js enable",
    "vscode:build": "npm --prefix vscode-extension run build",
    "vscode:package": "npm --prefix vscode-extension run package",
    "install:vscode": "node scripts/vscode-install.mjs install",
    "reinstall:vscode": "node scripts/vscode-install.mjs reinstall",
    "dev": "tsx src/cli.ts mcp",
    "start": "node dist/cli.js mcp"
  },
  "keywords": [
    "retentia",
    "codex",
    "mcp",
    "memory",
    "plugin",
    "claude",
    "qwen",
    "multi-agent"
  ],
  "author": "imre_gi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imre-gi/codex-mem.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
